rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles are private: only the owner can read or write their own.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /rooms/{roomId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // editorIds is optional on rooms created before the co-owner feature
      function editorsOf(data) {
        return ('editorIds' in data && data.editorIds is list) ? data.editorIds : [];
      }

      // editorNames (uid -> display name) is optional on rooms created before
      // the co-owner-label feature
      function editorNamesOf(data) {
        return ('editorNames' in data && data.editorNames is map) ? data.editorNames : {};
      }

      function isHost() {
        return isSignedIn() && request.auth.uid == resource.data.hostId;
      }

      function isEditor() {
        return isSignedIn() && request.auth.uid in editorsOf(resource.data);
      }

      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }

      // Cap the categories list so a hostile client can't bloat a (public)
      // room document toward the 1 MB limit — every viewer downloads the
      // full doc via onSnapshot. The app allows 6 categories; 12 leaves
      // headroom. Per-category fields (imageUrl, songUrl) can't be
      // validated here (rules can't iterate lists); the client validates
      // them and the hosting CSP (img-src) plus link sanitizing in the app
      // neutralize hostile values written via the raw API.
      function categoriesValid() {
        return !('categories' in request.resource.data)
          || (request.resource.data.categories is list
              && request.resource.data.categories.size() <= 12);
      }

      // Co-owners may change room content, but never ownership, membership,
      // the co-owner name map or the invite token.
      function isEditorContentUpdate() {
        return isEditor() && !changedKeys().hasAny(['hostId', 'editorIds', 'editorNames', 'inviteToken']);
      }

      // A user who proved they hold the current invite token (by creating a
      // join request, validated below) may add exactly their own uid to
      // editorIds, write their own entry in editorNames, and change nothing
      // else.
      function isSelfJoin() {
        return isSignedIn()
          && request.auth.uid != resource.data.hostId
          && 'inviteToken' in resource.data
          && resource.data.inviteToken is string
          && changedKeys().hasOnly(['editorIds', 'editorNames'])
          && request.resource.data.editorIds is list
          && request.resource.data.editorIds.toSet().hasAll(editorsOf(resource.data))
          && request.resource.data.editorIds.toSet().difference(editorsOf(resource.data).toSet()).hasOnly([request.auth.uid])
          && request.resource.data.editorNames is map
          && request.resource.data.editorNames.diff(editorNamesOf(resource.data)).affectedKeys().hasOnly([request.auth.uid])
          && get(/databases/$(database)/documents/rooms/$(roomId)/joinRequests/$(request.auth.uid)).data.token == resource.data.inviteToken;
      }

      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid
        && categoriesValid();
      allow read: if resource.data.isPublic == true || isHost() || isEditor();
      allow update: if (isHost() || isEditorContentUpdate() || isSelfJoin())
        && categoriesValid();
      allow delete: if isHost();

      // Category header images, split off the room document so the dashboard
      // and marketplace grids don't download them (see lib/categoryImages).
      // Same audience as the room itself, so these mirror the room's read and
      // content-write rules — via get(), since `resource` here is the asset
      // document, not the room.
      match /assets/{assetId} {
        function roomData() {
          return get(/databases/$(database)/documents/rooms/$(roomId)).data;
        }

        function canEditRoom() {
          return isSignedIn()
            && (request.auth.uid == roomData().hostId
                || request.auth.uid in editorsOf(roomData()));
        }

        allow read: if roomData().isPublic == true || canEditRoom();
        allow write: if canEditRoom();
      }

      // Invite handshake: an invitee writes the token from their invite link
      // here, and the rules compare it against the room's current token —
      // without ever letting them read the room. The doc doubles as the
      // co-owner's display info, since user profiles are private.
      match /joinRequests/{userId} {
        function roomData() {
          return get(/databases/$(database)/documents/rooms/$(roomId)).data;
        }

        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['token', 'displayName', 'email'])
          && request.resource.data.token is string
          && request.resource.data.token == roomData().inviteToken;

        allow read, delete: if request.auth != null
          && (request.auth.uid == userId || request.auth.uid == roomData().hostId);
      }
    }
  }
}
