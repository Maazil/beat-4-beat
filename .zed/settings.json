{
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.fixAll.oxc": true
  },
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSX": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "lsp": {
    "oxc": {
      "settings": {
        "config_path": ".oxlintrc.json"
      }
    }
  }
}
